# ==========================================
# DeployCost Dashboard - Environment Settings
# ==========================================

# GEMINI_API_KEY: Required for analyzing codebase structures and spec matching.
# AI Studio automatically injects this from your Secrets workspace panel.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The self-referential URL where this application is hosted.
# AI Studio automatically injects this at runtime with your active preview instance URL.
APP_URL="MY_APP_URL"

# SESSION_SECRET: Custom hashing secret key to sign Express session cookies.
SESSION_SECRET="deploycost-dashboard-super-secure-secret-key-99"

# ALLOW_DEV_LOGIN: Set to true to enable the offline sandbox credential form.
ALLOW_DEV_LOGIN="true"

# DB_PATH: Custom disk path to store the persistent SQLite database file.
DB_PATH="./data/deploycost.db"

# ==========================================
# OAuth Provider Settings (Google & GitHub)
# ==========================================

# GOOGLE_CLIENT_ID: Client identifier for Google Passport authentication.
GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET: Client private secret key for Google Passport authentication.
GOOGLE_CLIENT_SECRET=""

# GITHUB_CLIENT_ID: Client identifier for GitHub Passport authentication.
GITHUB_CLIENT_ID=""
# GITHUB_CLIENT_SECRET: Client private secret key for GitHub Passport authentication.
GITHUB_CLIENT_SECRET=""
